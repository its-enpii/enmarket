# ───── enmarket root environment ─────
# Salin ke .env (jangan commit), lalu edit sesuai kebutuhan.
# File ini di-load oleh docker-compose untuk semua service.

# ───── App ─────
APP_ENV=local
APP_URL=http://localhost:8000
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_NAME="enpiistudio"

# ───── Database (MySQL) ─────
DB_HOST=db
DB_PORT=3306
DB_DATABASE=enmarket
DB_USERNAME=enmarket
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ───── Tripay (payment gateway — Fase 3) ─────
# Daftar di https://tripay.co.id, ambil dari dashboard merchant
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_MODE=sandbox
TRIPAY_CALLBACK_URL=

# ───── EnStorage (file storage — Fase 4) ─────
# Orchestrator Google Drive enpiistudio.
# Kosongkan ENSTORAGE_BASE_URL untuk pakai LocalMockEnStorage (simpan di storage/app/private/).
# Isi dengan URL API EnStorage untuk pakai RemoteEnStorage (HTTP upload ke API).
ENSTORAGE_BASE_URL=
ENSTORAGE_API_KEY=

# ───── Evolution API (WhatsApp — Fase 4) ─────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=enpiistudio

# ───── n8n (workflow otomasi — Fase 4) ─────
N8N_WEBHOOK_KIRIM_PRODUK=

# ───── Mail (SMTP — Fase 4) ─────
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@enpiistudio.com

# ───── Admin auth (Fase 1) ─────
# Token statis untuk dashboard admin (single user)
ADMIN_TOKEN=

# ───── Next.js revalidation (Fase 2) ─────
# Laravel panggil endpoint ini di web container setelah admin CRUD.
# Default Docker DNS `http://web:3000` (antar-container di network yg sama).
NEXT_PUBLIC_SITE_URL=http://web:3000
# Set nilai unik production — entrypoint dev menggunakan dev-revalidate-secret.
REVALIDATE_SECRET=